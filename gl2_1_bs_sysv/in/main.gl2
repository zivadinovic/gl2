fun align_16(i64 n__size)
{
    return ((n__size + 15) / 16) * 16;
}

fun peek(i64 p__tokens, i64 refn__index)
{
    i64 n__slots = p__tokens[-1];
    i64 n__tmpid = refn__index[0];

    i64 n__tokid = p__tokens[n__tmpid];
    i64 s__tokval = p__tokens[n__tmpid + 1];

    i64 p__elem = arrinit(2);
    p__elem = arradd(p__elem, n__tokid);
    p__elem = arradd(p__elem, s__tokval);

    return p__elem;
}

fun consume(i64 p__tokens, i64 refn__index)
{
    i64 n__tmpid = refn__index[0];
    i64 n__tokid = p__tokens[n__tmpid];
    i64 s__tokval = p__tokens[n__tmpid + 1];

    i64 p__elem = arrinit(2);
    p__elem = arradd(p__elem, n__tokid);
    p__elem = arradd(p__elem, s__tokval);

    refn__index[0] = n__tmpid + 2;
    return p__elem;
}

fun expect(i64 p__tokens, i64 refn__index, i64 n__tokid)
{
    i64 p__peek = peek(p__tokens, refn__index), p__consume = 0;
    if (p__peek[0] == n__tokid)
    {
        p__consume = consume(p__tokens, refn__index);
        memfree(p__consume);
        memfree(p__peek);
        return 1;
    }

    memfree(p__peek);
    throw_error("unexpected");
    return 0;
}

fun accept(i64 p__tokens, i64 refn__index, i64 n__tokid)
{
    i64 p__peek = peek(p__tokens, refn__index), p__consume = 0;
    if (p__peek[0] == n__tokid)
    {
        p__consume = consume(p__tokens, refn__index);
        memfree(p__consume);
        memfree(p__peek);
        return 1;
    }

    memfree(p__peek);
    return 0;
}

fun parse_factor(i64 p__tokens, i64 refp__data, i64 refp__locals, i64 p__env)
{
    i64 p__regs = arrinit(6);
    p__regs = arradd(p__regs, "%rdi");
    p__regs = arradd(p__regs, "%rsi");
    p__regs = arradd(p__regs, "%rdx");
    p__regs = arradd(p__regs, "%rcx");
    p__regs = arradd(p__regs, "%r8");
    p__regs = arradd(p__regs, "%r9");

    i64 refn__index = p__env[0];
    i64 refn__strindex = p__env[1];
    i64 refn__mode = p__env[2];
    i64 refn__comparator = p__env[3];
    i64 refn__labelindex = p__env[4];

    i64 refn__localindex = p__env[5];
    i64 refs__body = p__env[7];

    i64 n__slots = p__tokens[-1];
    i64 n__current = refn__index[0];
    i64 p__tmparr = 0;

    i64 s__tmpstr = 0;
    i64 n__index = 0;
    i64 n__index1 = 0;
    i64 n__index2 = 0;
    i64 n__index3 = 0;

    i64 n__index4 = 0;
    i64 n__tmpflag = 0;
    i64 n__tmpflag1 = 0;
    i64 s__tokval = 0;

    if (n__current >= n__slots)
    {
        memfree(p__regs);
        return -1;
    }

    if (accept(p__tokens, refn__index, 1) == 1)
    {
        s__tokval = p__tokens[refn__index[0] - 1];

        p__tmparr = arrinit(1);
        p__tmparr = arradd(p__tmparr, s__tokval);
        s__tmpstr = strfmt("\tmovq $~s, %rax\n", @p__tmparr);
        refs__body[0] = strcat(refs__body[0], s__tmpstr);
        memfree(s__tmpstr);
        memfree(p__tmparr);
        memfree(p__regs);

        return 1;
    }

    if (accept(p__tokens, refn__index, 2) == 1)
    {
        n__index1 = refn__strindex[0];

        s__tokval = p__tokens[refn__index[0] - 1];
        refn__strindex[0] = refn__strindex[0] + 1;

        p__tmparr = arrinit(1);
        p__tmparr = arradd(p__tmparr, n__index1);

        s__tmpstr = strfmt(".str~i:\n", @p__tmparr);
        refp__data[0] = strcat(refp__data[0], s__tmpstr);
        memfree(p__tmparr);
        memfree(s__tmpstr);

        while (n__index < strlen(s__tokval))
        {
            p__tmparr = arrinit(1);

            p__tmparr = arradd(p__tmparr, s__tokval[n__index]);
            s__tmpstr = strfmt("\t.quad ~i\n", @p__tmparr);
            refp__data[0] = strcat(refp__data[0], s__tmpstr);
            memfree(p__tmparr);
            memfree(s__tmpstr);
            n__index = n__index + 1;
        }

        p__tmparr = arrinit(1);
        p__tmparr = arradd(p__tmparr, 0);
        s__tmpstr = strfmt("\t.quad ~i\n", @p__tmparr);

        refp__data[0] = strcat(refp__data[0], s__tmpstr);
        memfree(p__tmparr);
        memfree(s__tmpstr);

        p__tmparr = arrinit(1);
        p__tmparr = arradd(p__tmparr, n__index1);
        s__tmpstr = strfmt("\tleaq .str~i(%rip), %rax\n", @p__tmparr);

        refs__body[0] = strcat(refs__body[0], s__tmpstr);

        memfree(p__tmparr);
        memfree(s__tmpstr);
        memfree(p__regs);
        return 1;
    }

    if (accept(p__tokens, refn__index, 0) == 1)
    {
        s__tokval = p__tokens[refn__index[0] - 1];

        if (n__tmpflag1 == 0)
        {
            if (accept(p__tokens, refn__index, 11) == 1)
            {
                n__tmpflag1 = 1;

                p__tmparr = peek(p__tokens, refn__index);
                n__index3 = 1;

                if (p__tmparr[0] == 12)
                {
                    n__index3 = 0;
                }
                memfree(p__tmparr);

                if (n__index3 == 1)
                {
                    parse_expr(p__tokens, refp__data, refp__locals, p__env);

                    s__tmpstr = strfmt("\tpushq %rax\n");
                    refs__body[0] = strcat(refs__body[0], s__tmpstr);
                    n__index = n__index + 1;

                    memfree(s__tmpstr);

                    while (accept(p__tokens, refn__index, 17) == 1)
                    {
                        parse_expr(p__tokens, refp__data, refp__locals, p__env);

                        s__tmpstr = strfmt("\tpushq %rax\n");
                        refs__body[0] = strcat(refs__body[0], s__tmpstr);
                        n__index = n__index + 1;
                    }
                }

                expect(p__tokens, refn__index, 12);

                if (n__index > 6)
                {
                    n__index1 = n__index - 6;
                    n__tmpflag = 1;
                }
                if (n__tmpflag == 0)
                {
                    n__index1 = 0;
                }

                if (mmod((n__index1 * 8), 16) != 0)
                {
                    s__tmpstr = strfmt("\tsubq $8, %rsp\n");
                    refs__body[0] = strcat(refs__body[0], s__tmpstr);
                    memfree(s__tmpstr);
                }

                n__index2 = n__index - 1;

                while (n__index2 >= 0)
                {
                    if (n__index2 < 6)
                    {
                        s__tmpstr = p__regs[n__index2];

                        p__tmparr = arrinit(1);
                        p__tmparr = arradd(p__tmparr, s__tmpstr);
                        s__tmpstr = strfmt("\tpopq ~s\n", @p__tmparr);
                        refs__body[0] = strcat(refs__body[0], s__tmpstr);
                        memfree(p__tmparr);
                        memfree(s__tmpstr);
                    }
                    n__index2 = n__index2 - 1;
                }

                p__tmparr = arrinit(1);
                p__tmparr = arradd(p__tmparr, s__tokval);
                s__tmpstr = strfmt("\tcallq ~s\n", @p__tmparr);
                refs__body[0] = strcat(refs__body[0], s__tmpstr);
                memfree(s__tmpstr);
                memfree(p__tmparr);

                if (mmod((n__index1 * 8), 16) != 0)
                {
                    s__tmpstr = strfmt("\taddq $8, %rsp\n");
                    refs__body[0] = strcat(refs__body[0], s__tmpstr);
                    memfree(s__tmpstr);
                }

                memfree(p__regs);
                return 1;
            }
        }

        if (n__tmpflag1 == 0)
        {
            if (accept(p__tokens, refn__index, 15) == 1)
            {
                n__tmpflag1 = 1;

                n__index4 = refp__locals[0];
                n__index = find_var_offset(n__index4, s__tokval);
                n__index1 = n__index4[n__index + 1];

                p__tmparr = arrinit(1);
                p__tmparr = arradd(p__tmparr, n__index1);

                s__tmpstr = strfmt("\tmovq -~i(%rbp), %rax\n", @p__tmparr);
                refs__body[0] = strcat(refs__body[0], s__tmpstr);
                memfree(s__tmpstr);
                s__tmpstr = strfmt("\tpushq %rax\n");
                refs__body[0] = strcat(refs__body[0], s__tmpstr);
                memfree(s__tmpstr);

                memfree(p__tmparr);

                parse_expr(p__tokens, refp__data, refp__locals, p__env);

                expect(p__tokens, refn__index, 16);

                s__tmpstr = strfmt("\tpopq %rcx\n");
                refs__body[0] = strcat(refs__body[0], s__tmpstr);

                if (refn__mode[0] == 1)
                {
                    s__tmpstr = strfmt("\tleaq (%rcx, %rax, 8), %rax\n");
