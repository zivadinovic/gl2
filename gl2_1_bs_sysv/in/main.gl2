        if (n__index3 == 0)
        {
            if (refn__comparator[0] == 5)
            {
                s__tmpstr = strfmt("\tje .l~i\n", @n__index2);
                refs__body[0] = strcat(refs__body[0], s__tmpstr);
                memfree(s__tmpstr);
                n__index3 = 1;
            }
        }

        parse_block(p__tokens, refp__data, refp__locals, p__env);
        
        s__tmpstr = strfmt(".l~i:\n", @n__index2);
        refs__body[0] = strcat(refs__body[0], s__tmpstr);
        memfree(s__tmpstr);

        memfree(n__index2);
        memfree(p__regs);
        return 1;
    }

    if (accept(p__tokens, refn__index, 27) == 1)
    {
        n__index1 = refn__labelindex[0];
        refn__labelindex[0] = refn__labelindex[0] + 1;

        n__index4 = refn__labelindex[0];
        refn__labelindex[0] = refn__labelindex[0] + 1;

        n__index2 = arrinit(1);
        n__index2 = arradd(n__index2, n__index1);
        
        s__tmpstr = strfmt(".l~i:\n", @n__index2);
        refs__body[0] = strcat(refs__body[0], s__tmpstr);
        memfree(s__tmpstr);
        
        memfree(n__index2);

        expect(p__tokens, refn__index, 11);
        parse_comparison(p__tokens, refp__data, refp__locals, p__env);
        expect(p__tokens, refn__index, 12);

        n__index3 = 0;
        n__index2 = arrinit(1);
        n__index2 = arradd(n__index2, n__index4);

        if (n__index3 == 0)
        {
            if (refn__comparator[0] == 0)
            {
                s__tmpstr = strfmt("\tjne .l~i\n", @n__index2);
                refs__body[0] = strcat(refs__body[0], s__tmpstr);
                memfree(s__tmpstr);
                n__index3 = 1;
            }
        }
        if (n__index3 == 0)
        {
            if (refn__comparator[0] == 1)
            {
                s__tmpstr = strfmt("\tjge .l~i\n", @n__index2);
                refs__body[0] = strcat(refs__body[0], s__tmpstr);
                memfree(s__tmpstr);
                n__index3 = 1;
            }
        }
        if (n__index3 == 0)
        {
            if (refn__comparator[0] == 2)
            {
                s__tmpstr = strfmt("\tjle .l~i\n", @n__index2);
                refs__body[0] = strcat(refs__body[0], s__tmpstr);
                memfree(s__tmpstr);
                n__index3 = 1;
            }
        }
        if (n__index3 == 0)
        {
            if (refn__comparator[0] == 3)
            {
                s__tmpstr = strfmt("\tjg .l~i\n", @n__index2);
                refs__body[0] = strcat(refs__body[0], s__tmpstr);
                memfree(s__tmpstr);
                n__index3 = 1;
            }
        }
        if (n__index3 == 0)
        {
            if (refn__comparator[0] == 4)
            {
                s__tmpstr = strfmt("\tjl .l~i\n", @n__index2);
                refs__body[0] = strcat(refs__body[0], s__tmpstr);
                memfree(s__tmpstr);
                n__index3 = 1;
            }
        }
        if (n__index3 == 0)
        {
            if (refn__comparator[0] == 5)
            {
                s__tmpstr = strfmt("\tje .l~i\n", @n__index2);
                refs__body[0] = strcat(refs__body[0], s__tmpstr);
                memfree(s__tmpstr);
                n__index3 = 1;
            }
        }

        parse_block(p__tokens, refp__data, refp__locals, p__env);
        
        n__index3 = arrinit(1);
        n__index3 = arradd(n__index3, n__index1);
        s__tmpstr = strfmt("\tjmp .l~i\n", @n__index3);
        refs__body[0] = strcat(refs__body[0], s__tmpstr);
        memfree(s__tmpstr);
        memfree(n__index3);

        s__tmpstr = strfmt(".l~i:\n", @n__index2);
        refs__body[0] = strcat(refs__body[0], s__tmpstr);
        memfree(s__tmpstr);

        memfree(n__index2);
        memfree(p__regs);
        return 1;
    }

    if (accept(p__tokens, refn__index, 28) == 1)
    {
        if (accept(p__tokens, refn__index, 18) == 0)
        {
            parse_expr(p__tokens, refp__data, refp__locals, p__env);
            expect(p__tokens, refn__index, 18);
        }

        s__tmpstr = strfmt("\tleave\n\tretq\n");
        refs__body[0] = strcat(refs__body[0], s__tmpstr);
        memfree(s__tmpstr);
        
        memfree(p__regs);
        return 1;
    }

    if (accept(p__tokens, refn__index, 29) == 1)
    {
        parse_asm_block(p__tokens, refp__data, refp__locals, p__env);
        memfree(p__regs);
        return 1;
    }

    memfree(p__regs);
    return 1;
}

fun find_var_offset(i64 p__locals, i64 elem)
{
    i64 index = 0;
    i64 count = p__locals[-1];

    while (index < count)
    {
        if (strcmp(p__locals[index], elem) == 0)
        {
            return index;
        }

        index = index + 2;
    }

    return -1;
}

fun parse_var(i64 p__tokens, i64 refp__data, i64 refp__locals, i64 p__env)
{
    i64 n__index = 0;
    i64 n__index1 = 0;
    i64 n__index2 = 0;
    i64 n__index3 = 0;
    i64 s__tmpstr = 0;
    i64 p__tmparr = 0;
    i64 rp__locals = 0;

    i64 refn__index = p__env[0];
    i64 refn__localindex = p__env[5];
    i64 refs__body = p__env[7];

    rp__locals = 0;

    if (accept(p__tokens, refn__index, 25) == 1)
    {
        expect(p__tokens, refn__index, 0);
        
        n__index = p__tokens[refn__index[0] - 1];

        refn__localindex[0] = refn__localindex[0] + 8;
        
        rp__locals = refp__locals[0];

        n__index1 = find_var_offset(rp__locals, n__index);

        if (n__index1 == -1)
        {
            refp__locals[0] = arradd(refp__locals[0], n__index);
            refp__locals[0] = arradd(refp__locals[0], refn__localindex[0]);
        }
        if (n__index1 != -1)
        {
            n__index2 = refp__locals[0];
            n__index3 = n__index1 + 1;
            n__index2[n__index3] = refn__localindex[0];
        }

        expect(p__tokens, refn__index, 3);
        
        parse_expr(p__tokens, refp__data, refp__locals, p__env);

        p__tmparr = arrinit(1);
        p__tmparr = arradd(p__tmparr, refn__localindex[0]);
        s__tmpstr = strfmt("\tmovq %rax, -~i(%rbp)\n", @p__tmparr);
        
        refs__body[0] = strcat(refs__body[0], s__tmpstr);
        memfree(s__tmpstr);
        memfree(p__tmparr);

        while (accept(p__tokens, refn__index, 17) == 1)
        {
            expect(p__tokens, refn__index, 0);
            
            n__index = p__tokens[refn__index[0] - 1];

            refn__localindex[0] = refn__localindex[0] + 8;

            rp__locals = refp__locals[0];

            n__index1 = find_var_offset(rp__locals, n__index);
            
            if (n__index1 == -1)
            {
                refp__locals[0] = arradd(refp__locals[0], n__index);
                refp__locals[0] = arradd(refp__locals[0], refn__localindex[0]);
            }
            if (n__index1 != -1)
            {
                n__index2 = refp__locals[0];
                n__index3 = n__index1 + 1;
                n__index2[n__index3] = refn__localindex[0];
            }

            expect(p__tokens, refn__index, 3);
            
            parse_expr(p__tokens, refp__data, refp__locals, p__env);

            p__tmparr = arrinit(1);
            p__tmparr = arradd(p__tmparr, refn__localindex[0]);
            s__tmpstr = strfmt("\tmovq %rax, -~i(%rbp)\n", @p__tmparr);
            
            refs__body[0] = strcat(refs__body[0], s__tmpstr);
            memfree(s__tmpstr);
            memfree(p__tmparr);
        }

        expect(p__tokens, refn__index, 18);
        return 1;
    }

    return 1;
}

fun parse_block(i64 p__tokens, i64 refp__data, i64 refp__locals, i64 p__env)
{
    i64 n__index = 0;
    i64 n__index3 = 0;
    i64 n__flag = 0;
    i64 refn__index = p__env[0];

    expect(p__tokens, refn__index, 13);
    n__index3 = 1;
    
    n__index = peek(p__tokens, refn__index);

    if (n__index[0] == 14)
    {
        n__index3 = 0;
    }
    while (n__index3 == 1)
    {
        n__flag = 0;
        
        if (n__flag == 0)
        {
            if (n__index[0] == 25)
            {
                parse_var(p__tokens, refp__data, refp__locals, p__env);
                n__flag = 1;
            }
        }
        if (n__flag == 0)
        {
            parse_stmt(p__tokens, refp__data, refp__locals, p__env);
            n__flag = 1;
        }

        memfree(n__index);
        n__index = peek(p__tokens, refn__index);
        
        if (n__index[0] == 14)
        {
            n__index3 = 0;
        }
    }

    memfree(n__index);
    expect(p__tokens, refn__index, 14);
    return 1;
}

fun parse_asm_block(i64 p__tokens, i64 refp__data, i64 refp__locals, i64 p__env)
{
    i64 n__index = 0;
    i64 n__index1 = 0;
    i64 n__index2 = 0;
    i64 n__index3 = 0;
    i64 s__tmpstr = 0;

    i64 refn__index = p__env[0];
    i64 refs__body = p__env[7];

    expect(p__tokens, refn__index, 13);
    n__index3 = 1;
    
    n__index = peek(p__tokens, refn__index);

    if (n__index[0] == 14)
    {
        n__index3 = 0;
    }
    while (n__index3 == 1)
    {
        n__index1 = consume(p__tokens, refn__index);

        if (strlen(n__index1) != 0)
        {
            s__tmpstr = strfmt(n__index1[1]);
            refs__body[0] = strcat(refs__body[0], s__tmpstr);
            memfree(s__tmpstr);
        }

        memfree(n__index);
        memfree(n__index1);

        n__index = peek(p__tokens, refn__index);
        
        if (n__index[0] == 14)
        {
            n__index3 = 0;
        }

        memfree(n__index);
    }

    expect(p__tokens, refn__index, 14);
    return 1;
}

fun parse_func(i64 p__tokens, i64 refp__data, i64 refp__locals, i64 p__env)
{
    i64 p__regs = arrinit(6);
    p__regs = arradd(p__regs, "%rdi");
    p__regs = arradd(p__regs, "%rsi");
    p__regs = arradd(p__regs, "%rdx");
    p__regs = arradd(p__regs, "%rcx");
    p__regs = arradd(p__regs, "%r8");
    p__regs = arradd(p__regs, "%r9");
    
    i64 n__index = 0;
    i64 n__index1 = 0;
    i64 n__index2 = 0;
    i64 n__index3 = 0;
    i64 n__index4 = 0;
    i64 n__index5 = 0;
    i64 n__index6 = 0;
    i64 n__index7 = 0;
    i64 n__flag = 0;
    i64 n__flag1 = 0;
    i64 n__flag2 = 0;

    i64 refn__index = p__env[0];
    i64 refn__strindex = p__env[1];
    i64 refn__mode = p__env[2];
    i64 refn__comparator = p__env[3];
    i64 refn__labelindex = p__env[4];
    i64 refn__localindex = p__env[5];
    i64 refs__args = p__env[6];
    i64 refs__body = p__env[7];

    i64 rp__locals = 0;
    
    i64 n__current = refn__index[0];

    expect(p__tokens, refn__index, 24);
    expect(p__tokens, refn__index, 0);

    n__flag2 = refn__index[0] - 2;
    n__index7 = p__tokens[n__flag2 + 1];
    
    expect(p__tokens, refn__index, 11);

    if (accept(p__tokens, refn__index, 12) == 0)
    {
        expect(p__tokens, refn__index, 25);
        expect(p__tokens, refn__index, 0);

        n__flag = refn__index[0] - 2;
        n__index = p__tokens[n__flag + 1];

        refn__localindex[0] = refn__localindex[0] + 8;
        
        rp__locals = refp__locals[0];

        n__index1 = find_var_offset(rp__locals, n__index);

        if (n__index1 == -1)
        {
            refp__locals[0] = arradd(refp__locals[0], n__index);
            refp__locals[0] = arradd(refp__locals[0], refn__localindex[0]);
        }
        if (n__index1 != -1)
        {
            n__index2 = refp__locals[0];
            n__index3 = n__index1 + 1;
            n__index2[n__index3] = refn__localindex[0];
        }

        n__index4 = p__regs[n__flag1];
        n__flag1 = n__flag1 + 1;

        n__index5 = arrinit(2);
        n__index5 = arradd(n__index5, n__index4);
        n__index5 = arradd(n__index5, refn__localindex[0]);
        
        n__index6 = strfmt("\tmovq ~s, -~i(%rbp)\n", @n__index5);

        refs__body[0] = strcat(refs__body[0], n__index6);

        memfree(n__index5);
        memfree(n__index6);
        
        while (accept(p__tokens, refn__index, 17) == 1)
        {
            expect(p__tokens, refn__index, 25);
            expect(p__tokens, refn__index, 0);

            n__flag = refn__index[0] - 2;
            n__index = p__tokens[n__flag + 1];

            refn__localindex[0] = refn__localindex[0] + 8;
            
            rp__locals = refp__locals[0];

            n__index1 = find_var_offset(rp__locals, n__index);

            if (n__index1 == -1)
            {
                refp__locals[0] = arradd(refp__locals[0], n__index);
                refp__locals[0] = arradd(refp__locals[0], refn__localindex[0]);
            }
            if (n__index1 != -1)
            {
                n__index2 = refp__locals[0];
                n__index3 =  n__index1 + 1;
                n__index2[n__index3] = refn__localindex[0];
            }

            n__index4 = p__regs[n__flag1];
            n__flag1 = n__flag1 + 1;

            n__index5 = arrinit(2);
            n__index5 = arradd(n__index5, n__index4);
            n__index5 = arradd(n__index5, refn__localindex[0]);
            
            n__index6 = strfmt("\tmovq ~s, -~i(%rbp)\n", @n__index5);

            refs__body[0] = strcat(refs__body[0], n__index6);

            memfree(n__index5);
            memfree(n__index6);
        }

        expect(p__tokens, refn__index, 12);
    }

    parse_block(p__tokens, refp__data, refp__locals, p__env);
    
    n__index5 = arrinit(1);
    n__index5 = arradd(n__index5, n__index7);
    n__index6 = strfmt("~s:\n", @n__index5);
    refs__args[0] = strcat(refs__args[0], n__index6);
    memfree(n__index5);
    memfree(n__index6);
    
    n__index3 = strfmt("\tpushq %rbp\n");
    n__index5 = strfmt("\tmovq %rsp, %rbp\n");
    refs__args[0] = strcat(refs__args[0], n__index3);
    refs__args[0] = strcat(refs__args[0], n__index5);
    memfree(n__index3);
    memfree(n__index5);
    
    n__index3 = align_16(refn__localindex[0]);
    n__index5 = arrinit(1);
    n__index5 = arradd(n__index5, n__index3);
    n__index6 = strfmt("\tsubq $~i, %rsp\n", @n__index5);
    refs__args[0] = strcat(refs__args[0], n__index6);
    
    memfree(n__index5);
    memfree(n__index6);

    refs__args[0] = strcat(refs__args[0], refs__body[0]);

    n__index5 = arrinit(1);
    n__index5 = arradd(n__index5, refs__args[0]);
    printf("~s", @n__index5);
    memfree(n__index5);

    refp__locals[0] = arrinit(1);
    refn__localindex[0] = 0;
    refs__args[0] = arrinit(100000);
    refs__body[0] = arrinit(1000000);

    memfree(p__regs);
    return 1;
}

fun parse_program(i64 p__tokens, i64 refp__data, i64 refp__locals, i64 p__env)
{
    i64 refn__index = p__env[0];
    i64 refn__mode = p__env[2];
    i64 refn__comparator = p__env[3];
    i64 refn__labelindex = p__env[4];

    i64 n__index = 0;
    i64 n__index1 = 0;
    i64 n__flag = 0;
    
    while (refn__index[0] < p__tokens[-1])
    {
        n__index = peek(p__tokens, refn__index);
        
        if (n__flag == 0)
        {
            if (n__index[0] == 24)
            {
                parse_func(p__tokens, refp__data, refp__locals, p__env);
                n__flag = 1;
            }
        }
        if (n__flag == 0)
        {
            if (n__index[0] == 29)
            {
                memfree(consume(p__tokens, refn__index));
                parse_asm_block(p__tokens, refp__data, refp__locals, p__env);
                n__flag = 1;
            }
        }
        if (n__flag == 0)
        {
            throw_error("expected 'fun` or 'asm`");
            n__flag = 1;
        }

        memfree(n__index);

        n__flag = 0;
    }

    n__index1 = arrinit(1);
    n__index1 = arradd(n__index1, refp__data[0]);
    printf("~s", @n__index1);

    return 1;
}

fun main(i64 n__argc, i64 p2__argv)
{
    asm { "## (2n) --> tokenid\n" }
    asm { "## (2n + 1) --> tokenval\n" }
    asm { "## (2n) --> localid\n" }
    asm { "## (2n + 1) --> localval\n" }

    i64 s__fname = p2__argv[1];

    i64 n__newfd = open(s__fname, 66, 420);

    if (n__newfd == -1)
    {
        throw_error("open function fail");
        exit(1);
    }

    i64 n__fdsize = lseek(n__newfd, 0, 2);
    if (n__fdsize == -1)
    {
        throw_error("lseek function fail");
        exit(1);
    }

    if (lseek(n__newfd, 0, 0) == -1)
    {
        throw_error("lseek function fail (2)");
        exit(1);
    }

    i64 s__content = arrinit(n__fdsize + 1);
    i64 n__readbytes = 0, n__byte = 0;

    while (n__readbytes < n__fdsize)
    {
        read(n__newfd, @n__byte, 1);
        s__content[n__readbytes] = n__byte;
        n__readbytes = n__readbytes + 1;
    }

    if (n__readbytes == -1)
    {
        throw_error("couldnt set read bytes");
        exit(1);
    }

    s__content[-1] = n__readbytes;
    s__content[n__readbytes]=0;

    i64 p__tokens = tokenize(s__content);
    i64 n__tokencount = p__tokens[-1];
    i64 p__data = arrinit(1000000);
    i64 p__locals = arrinit(1000000);

    asm { "## [0] -> refn__tokenindex\n" }
    asm { "## [1] -> refn__strindex\n" }
    asm { "## [2] -> refn__mode\n" }
    asm { "## [3] -> refn__comparator\n" }
    asm { "## [4] -> refn__labelindex\n" }
    asm { "## [5] -> refn__localindex\n" }
    asm { "## [6] -> s__args\n" }
    asm { "## [7] -> s__body\n" }

    i64 n__tokenindex = 0;
    i64 n__strindex = 0;
    i64 n__mode = 0;
    i64 n__comparator = 0;
    i64 n__labelindex = 0;
    i64 n__localindex = 0;
    i64 s__args = arrinit(100000);
    i64 s__body = arrinit(1000000);

    i64 p__env = arrinit(8);
    p__env = arradd(p__env, @n__tokenindex);
    p__env = arradd(p__env, @n__strindex);
    p__env = arradd(p__env, @n__mode);
    p__env = arradd(p__env, @n__comparator);
    p__env = arradd(p__env, @n__labelindex);
    p__env = arradd(p__env, @n__localindex);
    p__env = arradd(p__env, @s__args);
    p__env = arradd(p__env, @s__body);

    parse_program(p__tokens, @p__data, @p__locals, p__env);

    memfree(p__tokens);
    memfree(s__args);
    memfree(s__body);
    memfree(p__env);

    close(n__newfd);
    memfree(s__content);

    return 0;
}
